<ResourceDictionary
  xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:shadui="clr-namespace:ShadUI.Controls;assembly=ShadUI" xmlns:v="clr-namespace:Everywhere.Views">

  <ControlTheme
    x:Key="{x:Type v:CustomAssistantInformationForm}"
    TargetType="v:CustomAssistantInformationForm">
    <Setter Property="Template">
      <ControlTemplate>
        <DockPanel HorizontalSpacing="16">
          <Button
            DockPanel.Dock="Left" Padding="0"
            VerticalAlignment="Top"
            CornerRadius="{DynamicResource FullCornerRadius}"
            ToolTip.Tip="{I18N {x:Static LocaleKey.CustomAssistantInformationForm_IconButton_ToolTip}}">
            <v:IconPresenter
              Width="72" Height="72"
              FontSize="{DynamicResource FontSize4Xl}"
              Icon="{Binding CustomAssistant.Icon, RelativeSource={RelativeSource TemplatedParent}, FallbackValue={x:Null}}"
              IconSize="{DynamicResource FontSize4Xl}"
              LineHeight="{DynamicResource LineHeight4Xl}"/>

            <Button.Flyout>
              <Flyout>
                <v:IconEditor
                  Width="360" Height="500"
                  Icon="{Binding CustomAssistant.Icon, RelativeSource={RelativeSource TemplatedParent}, FallbackValue={x:Null}}"/>
              </Flyout>
            </Button.Flyout>
          </Button>

          <StackPanel
            VerticalAlignment="Center" Spacing="4">
            <StackPanel
              Orientation="Horizontal" Spacing="4">
              <shadui:EditableTextBlock
                x:Name="PART_NameTextBlock" VerticalAlignment="Center"
                AcceptsReturn="False"
                FontSize="{DynamicResource FontSize2Xl}"
                FontWeight="Bold"
                PlaceholderText="{I18N {x:Static LocaleKey.CustomAssistant_EmptyName_PlaceholderText}}"
                Text="{Binding CustomAssistant?.Name, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>

              <Button
                Classes="Ghost Compact Uniform" VerticalAlignment="Bottom"
                shadui:ButtonAssist.Icon="{LucideIconContent PencilLine}"
                shadui:ButtonAssist.IconSize="{DynamicResource FontSizeM}"
                Command="{Binding #PART_NameTextBlock.EnterEditMode}"
                IsVisible="{Binding !#PART_NameTextBlock.IsEditing}"
                ToolTip.Tip="{I18N {x:Static LocaleKey.CustomAssistant_Name_Description}}"/>
            </StackPanel>

            <DockPanel
              HorizontalAlignment="Left" HorizontalSpacing="4">
              <Button
                Classes="Ghost Muted Compact Uniform" DockPanel.Dock="Right"
                VerticalAlignment="Top"
                shadui:ButtonAssist.Icon="{LucideIconContent PencilLine}"
                shadui:ButtonAssist.IconSize="{DynamicResource FontSizeM}"
                Command="{Binding #PART_DescriptionTextBlock.EnterEditMode}"
                IsVisible="{Binding !#PART_DescriptionTextBlock.IsEditing}"
                ToolTip.Tip="{I18N {x:Static LocaleKey.CustomAssistant_Description_Description}}"/>

              <ScrollViewer
                MaxHeight="60" HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <shadui:EditableTextBlock
                  x:Name="PART_DescriptionTextBlock" Classes="Muted"
                  Margin="0,0,6,0" VerticalAlignment="Center"
                  AcceptsReturn="True" MaxLength="4096"
                  PlaceholderText="{I18N {x:Static LocaleKey.CustomAssistant_EmptyDescription_PlaceholderText}}"
                  Text="{Binding CustomAssistant?.Description, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                  TextWrapping="Wrap"/>
              </ScrollViewer>
            </DockPanel>
          </StackPanel>
        </DockPanel>
      </ControlTemplate>
    </Setter>
  </ControlTheme>
</ResourceDictionary>
