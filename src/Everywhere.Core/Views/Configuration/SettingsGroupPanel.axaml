<ResourceDictionary
  xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:v="clr-namespace:Everywhere.Views">
  <ControlTheme
    x:Key="{x:Type v:SettingsGroupPanel}"
    TargetType="v:SettingsGroupPanel">
    <Setter Property="Template">
      <ControlTemplate>
        <StackPanel Spacing="8">
          <TextBlock
            Margin="0,4,0,0"
            IsVisible="{Binding $self.Text, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            Text="{TemplateBinding Header}"/>
          <ItemsPresenter/>
        </StackPanel>
      </ControlTemplate>
    </Setter>
  </ControlTheme>
</ResourceDictionary>
