<ResourceDictionary
  xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia" xmlns:plugins="clr-namespace:Everywhere.Chat.Plugins"
  xmlns:shadui="clr-namespace:ShadUI.Controls;assembly=ShadUI" xmlns:v="using:Everywhere.Views"
  xmlns:vc="clr-namespace:Everywhere.ValueConverters">
  <ControlTheme
    x:Key="{x:Type v:ChatActivityPreviewPresenter}"
    TargetType="v:ChatActivityPreviewPresenter">
    <Setter Property="Template">
      <ControlTemplate TargetType="v:ChatActivityPreviewPresenter">
        <ContentPresenter
          Content="{TemplateBinding Content}"
          ContentTemplate="{TemplateBinding ContentTemplate}"/>
      </ControlTemplate>
    </Setter>

    <Setter Property="shadui:BindingAssist.DataTemplates">
      <DataTemplates>
        <DataTemplate DataType="plugins:ChatPluginTextActivityPreview">
          <TextBlock
            Classes="Muted"
            FontSize="{DynamicResource FontSizeXs}"
            MaxLines="1"
            Text="{Binding TextKey^}"
            TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
        </DataTemplate>

        <DataTemplate DataType="plugins:ChatPluginCommandActivityPreview">
          <TextBlock
            Classes="Muted"
            FontSize="{DynamicResource FontSizeXs}"
            MaxLines="1" TextTrimming="CharacterEllipsis"
            TextWrapping="NoWrap">
            <TextBlock.Text>
              <I18N Key="{x:Static LocaleKey.BuiltInChatPlugin_Terminal_ExecuteScript_Preview}">
                <Binding Path="Command"/>
              </I18N>
            </TextBlock.Text>
          </TextBlock>
        </DataTemplate>

        <DataTemplate DataType="plugins:ChatPluginFileReferencesActivityPreview">
          <Grid
            ColumnDefinitions="Auto,*" ColumnSpacing="4">
            <TextBlock
              Classes="Muted" VerticalAlignment="Center"
              FontSize="{DynamicResource FontSizeXs}"
              IsVisible="{Binding PrefixKey, Converter={x:Static ObjectConverters.IsNotNull}}"
              Text="{Binding PrefixKey^}"
              TextWrapping="NoWrap"/>
            <ItemsControl
              Grid.Column="1" HorizontalAlignment="Stretch"
              ItemsSource="{Binding References}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <v:TrimmingStackPanel
                    MinimumLeadingVisibleItems="1" Orientation="Horizontal"
                    Spacing="4"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="plugins:ChatPluginFileReference">
                  <Button
                    Classes="Ghost Compact" Padding="5,1"
                    Command="{Binding OpenFileLocationCommand}"
                    ToolTip.Tip="{Binding FullPath}">
                    <Grid
                      ColumnDefinitions="Auto,*" ColumnSpacing="3">
                      <LucideIcon
                        Kind="File" Size="12"/>
                      <TextBlock
                        Grid.Column="1"
                        FontSize="{DynamicResource FontSizeXs}"
                        Text="{Binding FullPath}"
                        TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>
        </DataTemplate>

        <DataTemplate DataType="plugins:ChatPluginFileTransferActivityPreview">
          <StackPanel
            Orientation="Horizontal" Spacing="4">
            <Button
              Classes="Ghost Compact" Padding="5,1"
              Command="{Binding Source.OpenFileLocationCommand}"
              ToolTip.Tip="{Binding Source.FullPath}">
              <StackPanel
                Orientation="Horizontal" Spacing="3">
                <LucideIcon
                  Kind="File" Size="12"/>
                <TextBlock
                  FontSize="{DynamicResource FontSizeXs}"
                  Text="{Binding Source.FullPath}"
                  TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
              </StackPanel>
            </Button>
            <TextBlock
              Classes="Muted" Text="→"
              VerticalAlignment="Center"/>
            <Button
              Classes="Ghost Compact" Padding="5,1"
              Command="{Binding Destination.OpenFileLocationCommand}"
              ToolTip.Tip="{Binding Destination.FullPath}">
              <StackPanel
                Orientation="Horizontal" Spacing="3">
                <LucideIcon
                  Kind="File" Size="12"/>
                <TextBlock
                  FontSize="{DynamicResource FontSizeXs}"
                  Text="{Binding Destination.FullPath}"
                  TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="plugins:ChatPluginUrlsActivityPreview">
          <ItemsControl ItemsSource="{Binding Urls}">
              <ItemsControl.Styles>
                <Style Selector="Button.Link">
                  <Setter Property="Background" Value="{DynamicResource BorderColor30}"/>
                  <Setter Property="shadui:ButtonAssist.HoverBackground" Value="{DynamicResource SelectionColor}"/>
                  <Setter Property="Padding" Value="5,1"/>
                  <Setter Property="CornerRadius" Value="{DynamicResource FullCornerRadius}"/>
                </Style>
              </ItemsControl.Styles>
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <v:TrimmingStackPanel
                    MinimumLeadingVisibleItems="1" Orientation="Horizontal"
                    Spacing="4"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button
                    Classes="Ghost Compact Link"
                    Command="{Binding $parent[v:ChatMessageItemsControl].OpenUrlCommand}"
                    CommandParameter="{Binding}"
                    ToolTip.Tip="{Binding AbsoluteUri}">
                    <Grid
                      ColumnDefinitions="Auto,*" ColumnSpacing="3">
                      <Panel
                        Width="12" Height="12">
                        <Image
                          x:Name="FaviconImage" MaxWidth="12"
                          MaxHeight="12" md:AsyncImageLoader.SizeToContent="Manual"
                          md:AsyncImageLoader.Source="{Binding Converter={x:Static vc:UrlConverters.ToFaviconUrl}}"/>
                        <LucideIcon
                          IsVisible="{Binding #FaviconImage.Bounds.Width, Converter={x:Static vc:DoubleConverters.NotGreaterThan}, ConverterParameter=1}"
                          Kind="Link" Size="12"/>
                      </Panel>
                      <TextBlock
                        Grid.Column="1"
                        FontSize="{DynamicResource FontSizeXs}"
                        Text="{Binding Converter={x:Static vc:UrlConverters.ToHost}}"
                        TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
          </ItemsControl>
        </DataTemplate>

      </DataTemplates>
    </Setter>
  </ControlTheme>
</ResourceDictionary>