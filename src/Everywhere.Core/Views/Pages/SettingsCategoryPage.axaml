<UserControl
  x:Class="Everywhere.Views.Pages.SettingsCategoryPage" xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:p="clr-namespace:Everywhere.Views.Pages"
  xmlns:v="clr-namespace:Everywhere.Views">
  <DockPanel
    MaxWidth="1080" LastChildFill="True"
    VerticalSpacing="16">
    <TextBlock
      Classes="h4" DockPanel.Dock="Top"
      Margin="0,0,0,8" VerticalAlignment="Center"
      ClipToBounds="False"
      Text="{Binding $parent[p:SettingsCategoryPage].TitleKey^}"/>

    <ScrollViewer
      HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
      <v:SettingsItemsControl
        HorizontalAlignment="Stretch"
        ItemsSource="{Binding $parent[p:SettingsCategoryPage].Items}"/>
    </ScrollViewer>
  </DockPanel>
</UserControl>